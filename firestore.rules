rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Only the Admin SDK (server) can read or write permissions — never the client
    match /userPermissions/{userId} {
      allow read, write: if false;
    }

    // Anyone can submit an application (form is public); only the server can read/delete
    match /applicationSubmissions/{docId} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // Anyone can query applications by token field or update their own
    match /applications/{docId} {
      allow read, update: if true;
      allow create, delete: if false;
    }

    // Public read — needed for the apply form to show active competitions
    match /competitions/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Default: authenticated users can read/write their own data
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
